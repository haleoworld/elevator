# Copy to .env and fill in. Never commit .env.

# --- Required to boot ---

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Pick a strong password. You'll type this on your phone, so balance length and typeability.
DASHBOARD_PASSWORD=

# --- Required for the pipeline (screening, coaching, content, answer generation) ---
ANTHROPIC_API_KEY=

# --- Discovery sources (optional, per source) ---

# Adzuna job search API — fallback discovery for companies without a direct ATS scraper.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# SerpAPI (Google Jobs) — broad nightly keyword sweep. Free tier is ~250 searches/mo.
SERPAPI_KEY=

# --- Notifications (optional) ---

# Telegram bot for processing/discovery/batch pings. Create one via @BotFather.
TELEGRAM_BOT_TOKEN=

# --- Mobile / share-sheet ingest (optional) ---

# Shared secret for the iOS Shortcut / bookmarklet endpoints (/jobs/ingest, /coaching/ingest).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_TOKEN=

# --- jmc bridge (optional) ---

# Push batched jobs into the companion "Phone Screen" app, which stores its state
# in a private GitHub Gist. Needs the Gist id and a token with Gists read/write scope.
JMC_GIST_ID=
JMC_GIST_TOKEN=

# --- Deployment behind a path-based proxy, e.g. Tailscale Serve (optional) ---

# Path prefix the app is served under (e.g. /elevator-portal) so generated URLs and
# redirects work. Leave blank for plain localhost.
ELEVATOR_ROOT_PATH=

# Base URL used in notification links (your reachable https URL + the prefix above).
ELEVATOR_DASHBOARD_URL=
